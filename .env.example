# --- PATHS (required) ---
PYTHONPATH=src
DOCUMENT_BASE_PATH=./data/

# --- LLM / EMBEDDING PROVIDERS (required) ---
# Together API key (used by OpenAI-compatible generator client)
OPENAI_API_KEY=replace-with-together-api-key
# DeepInfra API key (used by embedding + reranking components)
DEEPINFRA_API_KEY=replace-with-deepinfra-api-key

# --- OPTIONAL LOCAL INFERENCE ENDPOINTS ---
TEI_EMBEDDING_ENDPOINT=http://localhost:1111/
TEI_RERANKER_ENDPOINT=http://localhost:2222/

# --- VECTOR DB (required) ---
QDRANT_ENDPOINT=https://your-qdrant-endpoint.example.com:6333
QDRANT_API_KEY=replace-with-qdrant-api-key
QDRANT_INDEX=your-collection-name
QDRANT_EMBEDDING_DIM=1024

# --- AUTHENTICATION (required when OAuth is enabled) ---
ENABLE_OAUTH=false
OAUTH_AUTHENTIK_URL_BASE=https://your-auth-provider.example.com/application/o/
OAUTH_AUTHENTIK_CLIENT_ID=replace-with-oauth-client-id
OAUTH_AUTHENTIK_CLIENT_SECRET=replace-with-oauth-client-secret
OAUTH_APPLICATION_NAME=your-application-name
OAUTH_AUTHENTIK_PRIVATE_KEY_PATH=/absolute/path/to/authentik_private_key.pem
CHAINLIT_AUTH_SECRET=replace-with-chainlit-auth-secret
